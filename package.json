{
  "name": "shadowflow-root",
  "version": "1.0.0",
  "description": "ShadowFlow - AI Shadowing Practice App Root",
  "scripts": {
    "install:all": "npm install && npm install --prefix frontend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "python -m uvicorn backend.app.main:app --reload --port 8000",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "start:backend": "python -m uvicorn backend.app.main:app --port 8000"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
